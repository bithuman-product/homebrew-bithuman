# Get your API secret at https://www.bithuman.ai → Developer → API Keys
BITHUMAN_API_SECRET=paste_your_api_secret_here

# For cloud-avatar.py only:
# Get your agent ID from https://www.bithuman.ai → Explore → click any agent → copy the code (e.g. A78WKV4515)
BITHUMAN_AGENT_ID=paste_your_agent_id_here

# For cloud-avatar.py only (LiveKit + OpenAI):
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
OPENAI_API_KEY=your_openai_api_key
