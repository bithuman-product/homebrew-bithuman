# LiveKit signal URL the browser connects to (WebSocket).
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.com

# Internal LiveKit URL used by server.js (defaults to http://livekit:17880
# inside docker-compose; set only if your server runs on a different host).
LIVEKIT_WS_URL=http://livekit:17880

# LiveKit API credentials — generate these from your LiveKit dashboard.
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Application configuration (JSON object for frontend settings).
NEXT_PUBLIC_APP_CONFIG={}

# Optional: avatar background image URL shown by the playground UI.
BITHUMAN_AVATAR_IMAGE=

# Optional: port the Next.js server listens on. Defaults to 3000.
PORT=3000
